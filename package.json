{
	"name": "obsidian-svelte-template",
	"version": "1.0.0",
	"description": "A starter template for building Obsidian plugins with Svelte, Vite, Bun, and Tailwind CSS.",
	"main": "main.js",
	"type": "module",
	"packageManager": "bun@1.3.10",
	"scripts": {
		"dev": "bun run dev:js & bun run dev:css",
		"dev:js": "vite build --watch --mode development",
		"dev:css": "tailwindcss -i ./src/tailwind.css -o ./styles.css --watch",
		"build": "tsc --noEmit && svelte-check --tsconfig ./tsconfig.json && vite build && tailwindcss -i ./src/tailwind.css -o ./styles.css --minify",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint .",
		"svelte-check": "svelte-check --tsconfig ./tsconfig.json"
	},
	"keywords": [
		"obsidian",
		"plugin",
		"svelte",
		"vite",
		"tailwindcss",
		"bun"
	],
	"license": "0-BSD",
	"devDependencies": {
		"@eslint/js": "9.30.1",
		"@sveltejs/vite-plugin-svelte": "^6.1.3",
		"@tailwindcss/cli": "^4.2.2",
		"@types/node": "^16.11.6",
		"eslint-plugin-obsidianmd": "0.1.9",
		"globals": "14.0.0",
		"jiti": "2.6.1",
		"svelte": "^5.38.2",
		"svelte-check": "^4.3.1",
		"tailwindcss": "^4.2.2",
		"tslib": "2.4.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "8.35.1",
		"vite": "^7.1.3"
	},
	"dependencies": {
		"obsidian": "latest"
	}
}
