{
	"compilerOptions": {
		"baseUrl": "src",
		"inlineSourceMap": true,
		"inlineSources": true,
		"module": "ESNext",
		"target": "ES2020",
		"moduleResolution": "bundler",
		"verbatimModuleSyntax": true,
		"importHelpers": true,
		"isolatedModules": true,
		"strict": true,
		"allowSyntheticDefaultImports": true,
		"skipLibCheck": true,
		"lib": [
			"DOM",
			"ES2020"
		]
	},
	"include": [
		"src/**/*.ts",
		"src/**/*.d.ts",
		"src/**/*.svelte",
		"vite.config.ts"
	]
}
